---
import { ArrowLeft } from "lucide-react";
import { formatDate } from "@/helpers/date";

interface Props {
  date: Date;
  description: string;
  readingTime: string;
  tags?: string[];
  title: string;
}

const { title, description, readingTime, date, tags } = Astro.props;
---

<section class="pt-40 pb-25">
  <div class="mb-8">
    <a
      href="/blog"
      class="text-xs font-medium text-muted-foreground inline-flex items-center gap-1"
    >
      <span><ArrowLeft size={12} /></span>
      Posts
    </a>
  </div>
  <h1 class="font-medium">{title}</h1>
  <p class="text-muted-foreground">{description}</p>
  <p class="mt-3 flex gap-2 uppercase text-xs">
    {formatDate(date)} <span>•</span> {readingTime}
  </p>
  {tags && (
      <div class="mt-6 font-mono text-xs text-muted-foreground uppercase flex flex-wrap gap-2">
        {tags.map((tag) => (
          <a href={`/blog/tags/${tag}`}>#{tag}</a>
        ))}
      </div>
    )}
</section>
